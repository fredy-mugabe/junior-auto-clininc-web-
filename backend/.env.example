PORT=4000

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Service role: Settings → API → service_role (keep secret; server only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Comma-separated emails allowed to call GET /api/applications
ADMIN_EMAILS=hakizap-2013@gmail.com

# CORS: your Vite dev server or production site
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Supabase Storage bucket for uploaded CVs (private)
CV_BUCKET=applications-cv
