# Supabase (Settings → API): Project URL and anon public key
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Dev: leave empty — Vite proxies /api to the backend (see vite.config.ts).
# Production: set your API origin, e.g. https://api.yourdomain.com
VITE_API_URL=

# Optional: external blog (full URL, no trailing slash). If unset, “official blog” uses this site: /blog
# VITE_OFFICIAL_BLOG_URL=https://example.com/blog

# Optional: canonical public site origin for absolute links (no trailing slash). If unset, uses browser origin + /blog
# VITE_SITE_URL=https://junior-auto-clininc-officalwebsite.vercel.app

# Optional: Google Maps iframe embed `src` for the About page (from Maps → Share → Embed).
# If unset, the app uses the built-in workshop embed.
# VITE_GOOGLE_MAPS_EMBED_SRC=
